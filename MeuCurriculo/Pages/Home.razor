@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4 shadow-sm">
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Fernando" class="rounded-circle mb-3 border border-3 border-primary"
                     width="120" />
                <h3 class="fw-bold">Fernando Braga</h3>
                <p class="text-muted small">Análise e Desenvolvimento de Sistemas | Estudante | Autônomo | Liderança em Inovação | Transformação Digital</p>
                <hr />
                <div class="text-start">
                    <h6 class="fw-bold">Contato</h6>
                    <p class="small mb-1"><i class="bi bi-envelope-fill me-2"></i> fernandoalmeidabh84@gmail.com</p>
                    <p class="small mb-1"><i class="bi bi-linkedin me-2"></i> linkedin.com/in/fernando-braga-48bb8134a</p>
                    <p class="small mb-1"><i class="bi bi-geo-alt-fill me-2"></i> Belo Horizonte, MG</p>
                </div>
                <hr />
                <div class="text-start">
                    <h6 class="fw-bold">Habilidades</h6>
                    <div class="d-flex flex-wrap gap-1">
                        <span class="badge bg-primary">MySQL</span>
                        <span class="badge bg-primary">PostgreSQL</span>
                        <span class="badge bg-primary">Linux</span>
                        <span class="badge bg-primary">Shell Script</span>
                        <span class="badge bg-primary">n8n</span>
                        <span class="badge bg-primary">C#</span>
                        <span class="badge bg-primary">.NET</span>
                        <span class="badge bg-primary">Blazor</span>
                        <span class="badge bg-primary">Pacote Office</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="mb-5">
                <h2 class="mb-3 fw-bold"><i class="bi bi-person-fill me-2"></i>Resumo Profissional</h2>
                <p class="text-justify">
                    Profissional com experiência em logística, administração e operações, atualmente em transição de carreira para a área de Tecnologia da Informação. 
                    Tenho histórico de atuação como Motorista Entregador e Auxiliar Administrativo de Obras, desenvolvendo competências em organização, controle de materiais, 
                    atendimento ao cliente e suporte a equipes.
                </p>
                <p class="text-justify">
                    Estou cursando Análise e Desenvolvimento de Sistemas (UNA BH, conclusão prevista para 2027), com formações complementares em Linux, Redes, Hardware e Bases Numéricas. 
                    Busco oportunidades como Analista de TI ou Estagiário em TI, onde possa aplicar conhecimentos em lógica de programação, banco de dados, automação e sistemas operacionais.
                </p>
            </div>

            <h2 class="mb-4 fw-bold"><i class="bi bi-briefcase-fill me-2"></i>Experiência Profissional</h2>
            
            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }

            <div class="mt-5">
                <h2 class="mb-4 fw-bold"><i class="bi bi-mortarboard-fill me-2"></i>Formação Acadêmica</h2>
                <div class="card border-0 shadow-sm p-3 mb-3">
                    <h5 class="fw-bold mb-1">Análise e Desenvolvimento de Sistemas</h5>
                    <p class="mb-0">Centro Universitário UNA</p>
                    <p class="text-muted small">2025 - 2027 (Previsão)</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia {
            Empresa = "Uber",
            Cargo = "Motorista",
            Inicio = "06/2025",
            Fim = "Presente",
            Descricao = "Atuação em transporte e logística urbana em Belo Horizonte, Minas Gerais."
        },
        new Experiencia {
            Empresa = "Empresa de Obras",
            Cargo = "Auxiliar Administrativo de Obras",
            Inicio = "Anterior",
            Descricao = "Organização, controle de materiais, atendimento ao cliente e suporte a equipes."
        }
    };
}